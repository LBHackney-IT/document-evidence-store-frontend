{
  "name": "document-evidence-service-frontend",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev-mock": "concurrently -k \"npm:mock\" \"next dev\"",
    "build": "next build --webpack",
    "clean": "eslint . --ext .js,.jsx,.ts,.tsx --fix && npx prettier --write .",
    "start": "next start",
    "start:ci": "concurrently -k \"npm:start\" \"npm:mock\"",
    "lint": "eslint . --max-warnings 0 --ext .js,.jsx,.ts,.tsx",
    "lint:ci": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "prettier:test": "npx prettier -c .",
    "prettier:fix": "npx prettier --write .",
    "test:unit": "jest",
    "test:unit:ci": "jest --ci --coverage --reporters=jest-junit --maxWorkers=2",
    "test:e2e:ci": "cypress run",
    "test:e2e:dev": "cypress open",
    "mock": "mocks-server",
    "prepare": "husky install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/nextjs": "^10.48.0",
    "axios": "1.15.0",
    "babel-plugin-superjson-next": "^0.4.5",
    "eslint-config-next": "^16.2.3",
    "file-type": "^16.5.4",
    "formik": "^2.4.5",
    "govuk-react": "^0.10.7",
    "heic2any": "0.0.3",
    "isomorphic-dompurify": "^2.21.0",
    "jsonwebtoken": "^9.0.3",
    "lbh-frontend": "^3.6.1",
    "luxon": "^1.25.0",
    "mime-types": "^2.1.28",
    "next": "^16.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "restana": "^4.8.0",
    "serve-static": "^1.14.1",
    "serverless-http": "^2.6.0",
    "styled-components": "^5.3.5",
    "superjson": "^1.13.3",
    "universal-cookie": "^7.2.2",
    "yup": "^0.31.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@mocks-server/main": "^4.1.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cypress-dotenv": "^3.0.0",
    "@types/gtag.js": "0.0.8",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/luxon": "^1.25.0",
    "@types/mime-types": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^8.3.0",
    "@types/yup": "^0.29.9",
    "axe-core": "^4.1.1",
    "concurrently": "^5.3.0",
    "cypress": "15.14.1",
    "cypress-axe": "1.7.0",
    "cypress-dotenv": "^3.0.1",
    "cypress-file-upload": "^5.0.8",
    "dotenv": "^10.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^15.14.0",
    "husky": "^8.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.8.2",
    "sass": "^1.98.0",
    "serverless": "^4.6.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "uuid": "^8.3.2",
    "wait-on": "^8.0.2"
  },
  "overrides": {
    "handlebars@4.7.7": "4.7.9"
  }
}
